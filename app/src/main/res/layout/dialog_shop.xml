<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Магазин улучшений"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#3E2723"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Пугало -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Пугало\nУвеличивает доход на 20%"
                android:textColor="#3E2723" />

            <TextView
                android:id="@+id/tvPriceScarecrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btnBuyScarecrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Купить" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Трактор -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Трактор\nУвеличивает силу клика"
                android:textColor="#3E2723" />

            <TextView
                android:id="@+id/tvPriceTractor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="800"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btnBuyTractor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Купить" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Поливалка -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Поливалка\nАвтополив раз в 10 сек"
                android:textColor="#3E2723" />

            <TextView
                android:id="@+id/tvPriceAutoWater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="600"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:layout_marginEnd="16dp" />

            <Button
                android:id="@+id/btnBuyAutoWater"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Купить" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
